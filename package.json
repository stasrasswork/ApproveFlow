{
  "name": "approveflow",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "@nestjs/platform-express": "11.1.21",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1"
  },
  "scripts": {
    "dev:api": "npm run start:dev -w api",
    "dev:web": "npm run dev -w web",
    "dev": "npm run dev:api & npm run dev:web",
    "build": "npm run build:api && npm run build:web",
    "build:api": "npm run build -w api",
    "build:web": "npm run build -w web",
    "lint": "npm run lint -w api && npm run lint -w web",
    "test": "npm run test:api && npm run test:web",
    "test:api": "npm run test -w api",
    "test:web": "npm run test -w web",
    "test:web:e2e": "bash scripts/e2e-web.sh"
  }
}
