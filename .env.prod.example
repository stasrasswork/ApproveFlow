# --- Required (set once; Postgres stores password on first volume init) ---
JWT_SECRET=replace-with-long-random-string-min-32-chars
POSTGRES_PASSWORD=replace-with-strong-password
CORS_ORIGIN=http://localhost:8080
APP_URL=http://localhost:8080
NODE_ENV=production
EXPOSE_DEBUG_TOKENS=false

# --- Email (required for password reset / workspace invites in real production) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ApproveFlow <noreply@example.com>

# --- Optional ---
WEB_PORT=8080
REDIS_URL=

# Smoke against compose stack:
#   API_URL=http://localhost:8080/api bash scripts/ops/smoke.sh
