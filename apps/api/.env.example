DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=public"
JWT_SECRET="change-me-in-production"
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"
PORT=3000

# Email (optional in dev — links are logged / returned in API responses)
APP_URL="http://localhost:5173"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ApproveFlow <noreply@example.com>"

# Rate limiting (optional — uses in-memory store when unset)
REDIS_URL=

# Dev-only: include raw tokens in auth/invite API responses
EXPOSE_DEBUG_TOKENS=false